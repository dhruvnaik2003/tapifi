generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  firstName       String
  lastName        String
  pfpUrl          String?
  bio             String?
  emailVerified   Boolean   @default(false)
  verificationOTP String?
  isProfileActive Boolean   @default(true)
  activeProfile   String    @default("personal") // personal | professional
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  links           Link[]
  chips           NfcChip[]
}

model Link {
  id        String   @id @default(uuid())
  platform  String
  url       String
  displayName String?
  showInPersonalProfile Boolean @default(true)
  showInProfessionalProfile Boolean @default(true)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NfcChip {
  id        String   @id @default(uuid())
  uid       String   @unique
  status    String   @default("unverified") // unverified | verified | activated
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
